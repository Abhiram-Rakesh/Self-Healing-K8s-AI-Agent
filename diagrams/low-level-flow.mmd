flowchart TB
    %% ── External ─────────────────────────────────────────────────────────────
    subgraph EXT["External"]
        direction LR
        DEV([Developer])
        GH[GitHub\nSource Repo]
        GHA[GitHub Actions\nCI · Lint · Test · Build]
        ANTHROPIC([Anthropic API\nClaude Haiku])
        SLACK([Slack\nHITL Approvals + Audit])
    end

    %% ── AWS Cloud ────────────────────────────────────────────────────────────
    subgraph AWS["☁ AWS Cloud — ap-south-1"]

        ECR[(ECR\nkagent-healer\nimage repo)]
        S3[(S3\nTF State Bucket\nversioned + encrypted)]

        subgraph IAM_BLOCK["IAM + OIDC"]
            direction TB
            OIDC[EKS OIDC\nProvider]
            IRSA[IRSA Role\nkagent-healer-irsa\nSecretsMgr + CW + S3]
            EBS_ROLE[EBS CSI\nIRSA Role]
            CLUSTER_ROLE[EKS Cluster\nIAM Role]
            NODE_ROLE[Node Group\nIAM Role\nWorkerNode+CNI+ECR+SSM]
        end

        subgraph SM["Secrets Manager"]
            SM_SLACK[kagent/slack-webhook]
            SM_GEMINI[kagent/gemini-api-key\noptional]
        end

        subgraph CW["CloudWatch"]
            CW_LOGS[Log Group\n/aws/eks/self-healing-cluster]
            CW_METRICS[Custom Metrics\nkagent namespace]
        end

        %% ── VPC ──────────────────────────────────────────────────────────────
        subgraph VPC["VPC  10.0.0.0/16"]

            IGW[Internet\nGateway]

            subgraph PUB["Public Subnets × 3 AZs"]
                EIP[Elastic IP]
                NAT[NAT Gateway]
            end

            subgraph PRIV["Private Subnets × 3 AZs"]

                subgraph EKS_CP["EKS Control Plane  (AWS-managed)"]
                    APISERVER[Kubernetes\nAPI Server]
                    CP_SG[Control Plane\nSecurity Group]
                end

                subgraph SYS_NG["System Node Group  t3.medium × 2  ON_DEMAND"]
                    COREDNS[CoreDNS\naddon]
                    KPROXY[kube-proxy\naddon]
                    VPCCNI[vpc-cni\naddon]
                end

                subgraph WORK_NG["Workload Node Group  t3.large  ON_DEMAND + SPOT"]

                    subgraph NS_MON["namespace: monitoring"]
                        PROM[Prometheus\n:9090]
                        AM[Alertmanager\n:9093]
                        GRAFANA[Grafana\n:3000]
                        LOKI[Loki\n:3100]
                        PROMTAIL[Promtail\nDaemonSet]
                        KSM[kube-state-\nmetrics]
                        NE[node-exporter\nDaemonSet]
                    end

                    subgraph NS_KAGENT["namespace: kagent"]
                        KAGENT_CTRL[kagent Controller\n:8083]
                        HEALER_AG[healer-agent\nAgent CRD]
                        KAGENT_TS[kagent-tool-server\nBuilt-in K8s MCP]
                    end

                    subgraph NS_DEFAULT["namespace: default"]
                        BRIDGE[Bridge\n:8000\nAlertmanager webhook]
                        MCP[healer-mcp-server\nFastMCP SSE :8080]
                        POSTGRES[(PostgreSQL\nIncident Memory\nBitnami StatefulSet :5432)]
                        SQLITE[(SQLite\nIncident Memory\nlocal dev fallback)]
                        AUDIT[(Audit Log\nJSONL\n/data/kagent-audit.jsonl)]
                    end

                    subgraph NS_LITMUS["namespace: litmus"]
                        LITMUS[Litmus Chaos\nOperator]
                        CHAOS_ENG[ChaosEngine CRD\npod-delete]
                    end

                    EBS_VOL[(EBS Volumes\ngp3 — dynamic PVCs\nLoki · Prometheus)]
                end
            end
        end
    end

    %% ═══════════════════════════════════════════════════════════════════════
    %% CONNECTIONS
    %% ═══════════════════════════════════════════════════════════════════════

    %% Developer → CI/CD
    DEV -->|git push| GH
    GH -->|trigger| GHA
    GHA -->|docker buildx push| ECR
    GHA -->|lint · test · terraform plan| S3

    %% Networking spine
    IGW --> EIP --> NAT
    NAT -->|egress| PRIV

    %% IAM wiring
    OIDC -->|federates| IRSA
    OIDC -->|federates| EBS_ROLE
    CLUSTER_ROLE -->|AmazonEKSClusterPolicy| EKS_CP
    NODE_ROLE -->|AmazonEKSWorkerNodePolicy\nAmazonEKS_CNI_Policy\nAmazonEC2ContainerRegistryReadOnly\nAmazonSSMManagedInstanceCore| SYS_NG
    NODE_ROLE --> WORK_NG
    EBS_ROLE -->|AmazonEBSCSIDriverPolicy| EBS_VOL
    IRSA -->|GetSecretValue| SM_SLACK
    IRSA -->|PutMetricData · PutLogEvents| CW_METRICS

    %% Image pull
    ECR -->|image pull on deploy| NS_DEFAULT

    %% EKS control plane → CloudWatch
    EKS_CP -->|control plane audit logs| CW_LOGS

    %% Monitoring scrape
    KSM -->|k8s object metrics| PROM
    NE -->|node metrics| PROM
    PROM -->|AlertmanagerConfig\nkagent:true label| AM
    PROMTAIL -->|pod log streams| LOKI
    GRAFANA -->|PromQL queries| PROM
    GRAFANA -->|LogQL queries| LOKI

    %% Alert → Bridge → Agent
    AM -->|POST /webhook\nfiring alerts| BRIDGE
    BRIDGE -->|dedup · budget guard| BRIDGE
    BRIDGE -->|A2A v0.3.0\nPOST message/send| KAGENT_CTRL
    KAGENT_CTRL -->|spawn agent run| HEALER_AG

    %% Agent tool-calling loop
    HEALER_AG -->|k8s_get_pod_logs\nk8s_get_events\nk8s_describe_resource\nk8s_get_resources| KAGENT_TS
    KAGENT_TS -->|kubectl reads| APISERVER
    HEALER_AG -->|_mcp_recall_past_cases\n_mcp_restart_deployment\n_mcp_scale_deployment\n_mcp_cordon_node\n_mcp_drain_node\n_mcp_record_outcome| MCP
    MCP -->|safety-gated writes\nconfidence + namespace + dry-run gates| APISERVER
    MCP <-->|SELECT / INSERT incidents\nDATABASE_URL set — production| POSTGRES
    MCP <-.->|SELECT / INSERT incidents\nlocal dev fallback| SQLITE
    POSTGRES -.->|PVC 5Gi gp3| EBS_VOL
    MCP -->|append JSONL| AUDIT

    %% LLM
    KAGENT_CTRL <-->|tool-calling loop\nClaude Haiku| ANTHROPIC

    %% Outcomes
    MCP -->|PutMetricData\nkagent_alerts_total etc| CW_METRICS
    MCP -->|HITL approval request\naudit notifications| SLACK
    BRIDGE -->|POST /approve/id\nHTLP approval relay| MCP

    %% Litmus
    LITMUS -->|executes| CHAOS_ENG
    CHAOS_ENG -->|pod delete fault| NS_DEFAULT

    %% PVC → EBS
    LOKI -.->|PVC| EBS_VOL
    PROM -.->|PVC| EBS_VOL

