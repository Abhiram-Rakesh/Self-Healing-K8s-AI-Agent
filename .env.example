# Copy this file to .env and fill in real values for local development.
# Never commit a populated .env file.
#
# NOTE: The Gemini API key is NOT used by the healer pod directly.
# It is managed by kagent via the `kagent-gemini` K8s secret and ModelConfig CRD.
# Set it here only if running mcp_server.py standalone outside of kagent.

# Kubernetes / kubeconfig (local dev only — in-cluster uses ServiceAccount)
KUBECONFIG=/home/youruser/.kube/config

# Agent behavior
DRY_RUN=true
CONFIDENCE_THRESHOLD=0.75
MAX_REPLICAS=10
DAILY_REQUEST_LIMIT=200
MEMORY_DB_PATH=/tmp/kagent-memory.db
AUDIT_LOG_PATH=/tmp/kagent-audit.jsonl
LOG_LEVEL=INFO

# AWS (only used when running in-cluster on EKS)
AWS_REGION=ap-south-1
SECRETS_MANAGER_REGION=ap-south-1
SLACK_WEBHOOK_SECRET=kagent/slack-webhook

# Optional notifications
SLACK_WEBHOOK_URL=

# Bridge → kagent forwarding
KAGENT_CONTROLLER_URL=http://kagent-controller.kagent.svc.cluster.local:8083
KAGENT_NAMESPACE=kagent
KAGENT_AGENT_NAME=healer-agent

# MCP server port (kagent calls write tools here via SSE)
MCP_PORT=8080

# Webhook security (leave empty to disable auth for local dev)
WEBHOOK_TOKEN=
# External base URL of this service — used to build the /approve/<id> link in Slack HITL messages
WEBHOOK_BASE_URL=http://localhost:8000
# Seconds to wait for human approval of cordon_node/drain_node before auto-approving
APPROVAL_TIMEOUT_SECONDS=300
